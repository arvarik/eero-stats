# Container user mapping (run `id` on your host to find these)
PUID=1000
PGID=1000

# Eero Account credentials
EERO_LOGIN=user@example.com

# Session file path (optional — defaults to /app/data/.eero_session.json
# inside Docker, or data/app/.eero_session.json locally)
# EERO_SESSION_PATH=data/app/.eero_session.json

# InfluxDB Configuration
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=my-super-secret-auth-token-123
INFLUX_ORG=eero-stats-org
INFLUX_BUCKET=eero
INFLUX_USERNAME=admin
INFLUX_PASSWORD=secretpassword

# Port mappings (change if these conflict with existing services)
GRAFANA_PORT=3000
INFLUX_PORT=8086

# Grafana Admin (change for production!)
GF_ADMIN_PASSWORD=admin
